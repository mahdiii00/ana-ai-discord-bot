# === REQUIRED ===
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Get this from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# === OPTIONAL ===
# Groq model (default: llama-3.3-70b-versatile, free tier)
GROQ_MODEL=llama-3.3-70b-versatile

# Prefix for text commands (default: ai)
PREFIX=ai

# Comma-separated role IDs that bypass permission checks
ADMIN_ROLE_IDS=123456789,987654321

# Channel ID for action logs
LOG_CHANNEL_ID=123456789
